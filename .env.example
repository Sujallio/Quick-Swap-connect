# Supabase Environment Variables
# Get these from your Supabase project dashboard: https://supabase.com/dashboard

# Your Supabase API key (public/anon key) - safe to expose in frontend
VITE_SUPABASE_PUBLISHABLE_KEY=your_publishable_key_here

# Your Supabase project URL
VITE_SUPABASE_URL=https://your-project.supabase.co

# Your Supabase project ID (extracted from URL above)
VITE_SUPABASE_PROJECT_ID=your-project-id

# Non-Vite prefixed variables (also used by backend/CLI)
SUPABASE_PUBLISHABLE_KEY=your_publishable_key_here
SUPABASE_URL=https://your-project.supabase.co

# Optional: Razorpay configurations (if handling payments server-side)
# VITE_RAZORPAY_KEY_ID=your_razorpay_key
