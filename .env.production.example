# Production Environment Variables Template
# Copy this to your deployment platform and fill in the actual values
# Never commit .env.production to git

# === REQUIRED: Supabase Configuration ===
# From: https://supabase.com/dashboard → Settings → API

# Production Supabase Project URL
VITE_SUPABASE_URL=https://your-production-project.supabase.co

# Production Supabase Publishable Key (safe for frontend)
VITE_SUPABASE_PUBLISHABLE_KEY=eyJhbGci...your-production-key...

# Supabase Project ID (extracted from URL)
VITE_SUPABASE_PROJECT_ID=your-production-project-id

# Non-Vite prefixed for CLI/backend usage
SUPABASE_URL=https://your-production-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=eyJhbGci...your-production-key...

# === RAZORPAY PAYMENT (UPI ONLY) ===
# IMPORTANT: These should be set in Supabase Edge Function Secrets only
# NOT in this environment file (for security)
# Configure in Supabase Dashboard → Edge Functions → Secrets:
#   - RAZORPAY_KEY_ID=rzp_live_XXXXX (get from Razorpay Dashboard)
#   - RAZORPAY_KEY_SECRET=XXXXX (get from Razorpay Dashboard)
#   - ANON_KEY=your_anon_key (from Supabase Settings → API)

# === OPTIONAL: Analytics & Monitoring ===
# VITE_SENTRY_DSN=https://your-sentry-dsn
# VITE_GA_TRACKING_ID=your-google-analytics-id

# === NODE ENVIRONMENT ===
NODE_ENV=production

# === DEPLOYMENT PLATFORM SPECIFIC ===
# Vercel (deployment automatically configured via vercel.json)
# VERCEL=1
# VERCEL_ENV=production

# === SECURITY ===
# Set to your production domain for CORS
VITE_ALLOWED_DOMAIN=https://your-domain.com
